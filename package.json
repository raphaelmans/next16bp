    "lint:assertions": "tsx scripts/quality/assertion-gate.ts",
    "lint:arch": "bash scripts/architecture/check-client-conformance.sh",
    "validate:client-arch": "pnpm lint && pnpm lint:arch",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
