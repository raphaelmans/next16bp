{
  "name": "next16bp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:grab": "pnpm dlx @react-grab/opencode@latest && next dev",
    "dev": "next dev",
    "dev:local": "dotenvx run --env-file=.env.local -- next dev",
    "dev:production": "dotenvx run --env-file=.env.production -- next dev",
