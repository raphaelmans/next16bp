{
  "format": "csv",
  "version": 1,
  "dateTimeMode": "date_start_end_time",
  "resource": { "kind": "column", "column": { "header": "court" } },
  "sport": { "kind": "column", "column": { "header": "sport" } },
  "reason": { "kind": "column", "column": { "header": "reason" } },
  "start": {
    "date": { "header": "start_date" },
    "time": { "header": "start_time" }
  },
  "end": {
    "date": { "header": "end_date" },
    "time": { "header": "end_time" }
  },
  "parsing": {
    "timeZoneFallback": "Asia/Manila",
    "dateOrder": "ymd",
    "timeFormat": "24h",
    "assumeTimeZoneWhenMissingOffset": true
  }
}
