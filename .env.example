# Copy to .env.local (do not commit secrets)

# --- Required (server) ---
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SECRET_KEY=
RESEND_API_KEY=
CONTACT_US_FROM_EMAIL=
CONTACT_US_TO_EMAIL=

# --- Required (client) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Recommended (production canonical origin)
NEXT_PUBLIC_APP_URL=

# --- Optional integrations ---
CHAT_PROVIDER=stream
CHAT_POC_ENABLED=false
STREAM_CHAT_API_KEY=
STREAM_CHAT_API_SECRET=

GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY=
NEXT_PUBLIC_MIXPANEL_TOKEN=
OPENAI_API_KEY=

# SMS (optional)
SEMAPHORE_API_KEY=
SEMAPHORE_SENDER_NAME=
SEMAPHORE_BASE_URL=

# Notifications (optional; defaults enabled)
NOTIFICATION_EMAIL_ENABLED=true
NOTIFICATION_SMS_ENABLED=true
ENABLE_ADDON_PRICING_V2=true

# Web Push notifications (optional)
NOTIFICATION_WEB_PUSH_ENABLED=true
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_SUBJECT=

# Cron protection (required outside local development)
CRON_SECRET=

# QStash queue trigger (optional; enables sub-minute notification dispatch)
QSTASH_URL=
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
NOTIFICATION_DISPATCH_TRIGGER_URL=

# Upstash (rate limiting + caching, required outside local development)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Playwright E2E (optional, for local e2e against authenticated flows)
E2E_BASE_URL=http://localhost:3000
E2E_OWNER_EMAIL=
E2E_OWNER_PASSWORD=
E2E_PLAYER_EMAIL=
E2E_PLAYER_PASSWORD=
E2E_PLAYER_VENUE_SLUG=testerz
